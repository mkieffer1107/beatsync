# Production LAN-only settings used by `bun run lan:prod`.
# Leave API/WS blank so the client falls back to same-origin URLs via Caddy.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=
# `scripts/run-lan-stack.sh` reads CLIENT_HOSTNAME / CLIENT_PORT and then maps
# them to Next's HOSTNAME / PORT without colliding with the shell's own HOSTNAME.
CLIENT_HOSTNAME=127.0.0.1
CLIENT_PORT=3000
