# Production LAN-only settings used by `bun run lan:prod`.
# Keep LOCAL_STORAGE_ROOT relative so files stay under apps/server/storage.
LOCAL_STORAGE_ROOT=./storage
PUBLIC_BASE_URL=http://vibe.mathnasium.pro
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
# Optional: only set one of the cookie env vars below if a specific YouTube
# video needs an authenticated browser session.
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES_FILE=/absolute/path/to/youtube-cookies.txt
